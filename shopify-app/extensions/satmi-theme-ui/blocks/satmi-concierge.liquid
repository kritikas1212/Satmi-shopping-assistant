{% liquid
  assign satmi_url = block.settings.nextjs_url | strip
  if satmi_url == blank
    assign satmi_url = 'https://satmi-shopping-assistant.vercel.app'
  endif
%}

<iframe
  id="satmi-chat-iframe"
  src="{{ satmi_url }}"
  title="SATMI AI Concierge"
  loading="lazy"
  allow="clipboard-write"
></iframe>

<style>
  #satmi-chat-iframe {
    position: fixed;
    right: 20px;
    bottom: 50px;
    width: 80px;
    height: 80px;
    border: 0;
    border-radius: 16px;
    background: transparent;
    z-index: 9999;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  #satmi-chat-iframe.is-open {
    width: 400px;
    height: 750px;
    border-radius: 16px;
  }

  @media (max-width: 768px) {
    #satmi-chat-iframe.is-open {
      right: 10px;
      bottom: 50px;
      width: calc(100vw - 20px);
      height: calc(100vh - 70px);
      border-radius: 14px;
    }
  }
</style>

<script>
  (function() {
    var iframe = document.getElementById('satmi-chat-iframe');
    if (!iframe) return;

    var BASE_BOTTOM = 50;
    var STICKY_OFFSET = 80;
    var mobileQuery = window.matchMedia('(max-width: 768px)');
    var stickySelectors = [
      '.sticky-atc',
      '.sticky-add-to-cart',
      '.product-sticky-atc',
      '.product-form__buttons--sticky',
      '[data-sticky-atc]',
      '[data-sticky-add-to-cart]'
    ];

    function isStickyAtcVisible() {
      var elements = document.querySelectorAll(stickySelectors.join(','));
      for (var i = 0; i < elements.length; i += 1) {
        var node = elements[i];
        if (!(node instanceof HTMLElement)) continue;
        var style = window.getComputedStyle(node);
        if (style.display === 'none' || style.visibility === 'hidden' || Number(style.opacity) === 0) continue;

        var rect = node.getBoundingClientRect();
        if (rect.width < 20 || rect.height < 20) continue;

        var touchesBottom = rect.top < window.innerHeight && rect.bottom > window.innerHeight - rect.height;
        if (touchesBottom) {
          return true;
        }
      }
      return false;
    }

    function syncIframeBottomOffset() {
      if (!mobileQuery.matches) {
        iframe.style.bottom = BASE_BOTTOM + 'px';
        return;
      }

      var nextBottom = isStickyAtcVisible() ? BASE_BOTTOM + STICKY_OFFSET : BASE_BOTTOM;
      iframe.style.bottom = nextBottom + 'px';
    }

    window.addEventListener('message', function(event) {
      if (event.data && event.data.type === 'SATMI_CHAT_TOGGLE') {
        if (event.data.isOpen) {
          iframe.classList.add('is-open');
        } else {
          iframe.classList.remove('is-open');
        }
        syncIframeBottomOffset();
      }
    });

    var observer = new MutationObserver(syncIframeBottomOffset);
    if (document.body) {
      observer.observe(document.body, { childList: true, subtree: true, attributes: true });
    }

    window.addEventListener('resize', syncIframeBottomOffset, { passive: true });
    window.addEventListener('scroll', syncIframeBottomOffset, { passive: true });
    window.addEventListener('orientationchange', syncIframeBottomOffset, { passive: true });

    syncIframeBottomOffset();
  })();
</script>

{% schema %}
{
  "name": "SATMI AI Concierge",
  "target": "body",
  "settings": [
    {
      "type": "url",
      "id": "nextjs_url",
      "label": "Next.js App URL"
    }
  ]
}
{% endschema %}
