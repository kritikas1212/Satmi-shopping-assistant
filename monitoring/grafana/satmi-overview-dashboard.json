{
  "title": "SATMI Chatbot Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (RPS)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(satmi_http_requests_total[1m]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "5xx Error Rate",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(satmi_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(satmi_http_requests_total[5m]))",
          "legendFormat": "5xx_rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "P95 Latency (s)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(satmi_http_request_duration_seconds_bucket{path!=\"/metrics\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Handoffs Created / min",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(satmi_handoffs_created_total[1m]))",
          "legendFormat": "handoffs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Rate Limit Hits / min",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(satmi_rate_limit_hits_total[1m]))",
          "legendFormat": "rate_limit_hits",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Shopify Errors by Class",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (error_class) (rate(satmi_shopify_errors_total[5m]))",
          "legendFormat": "{{error_class}}",
          "refId": "A"
        }
      ]
    }
  ]
}
