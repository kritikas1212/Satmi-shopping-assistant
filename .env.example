LLM_PROVIDER=gemini
MODEL_NAME=gemini-2.0-flash
GEMINI_API_KEY=your_gemini_key_here
LLM_RESPONSE_REFINEMENT_ENABLED=false
APP_ENV=dev
API_PORT=8000
DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/satmi_chatbot
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01
AUTH_REQUIRED=false
API_KEY=change_this_to_a_strong_secret
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
SHOPIFY_TIMEOUT_SECONDS=15
SHOPIFY_MAX_RETRIES=2
OBSERVABILITY_ENABLED=true
METRICS_ENDPOINT_ENABLED=true
METRICS_ENDPOINT_PATH=/metrics
TRACING_ENABLED=true
TRACING_SERVICE_NAME=satmi-chatbot
TRACING_EXPORTER=otlp
TRACING_OTLP_ENDPOINT=http://localhost:4318/v1/traces
TRACING_TIMEOUT_SECONDS=5
POLICY_KB_PATH=./data/policy_kb.json
POLICY_RETRIEVAL_MAX_ITEMS=3
HITL_INTERRUPT_ENABLED=false
ASYNC_CANCEL_ENABLED=false
REDIS_URL=redis://localhost:6379/0
CANCEL_QUEUE_KEY=satmi:cancel:queue
