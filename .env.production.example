# App runtime
APP_ENV=prod
API_PORT=8000
AUTH_REQUIRED=true
API_KEY=replace_with_long_random_secret
DATABASE_URL=postgresql+psycopg://username:password@postgres-host:5432/satmi_chatbot

# Model + external services
LLM_PROVIDER=gemini
MODEL_NAME=gemini-2.0-flash
GEMINI_API_KEY=replace_with_gemini_key
GEMINI_INTENT_CLASSIFIER_API_KEY=replace_with_classifier_gemini_key
LLM_RESPONSE_REFINEMENT_ENABLED=true
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=replace_with_shopify_token
SHOPIFY_API_VERSION=2025-01

# Reliability controls
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
SHOPIFY_TIMEOUT_SECONDS=15
SHOPIFY_MAX_RETRIES=2

# Metrics + tracing
OBSERVABILITY_ENABLED=true
METRICS_ENDPOINT_ENABLED=true
TRACING_ENABLED=true
TRACING_EXPORTER=otlp
TRACING_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
TRACING_TIMEOUT_SECONDS=5
POLICY_KB_PATH=./data/policy_kb.json
POLICY_RETRIEVAL_MAX_ITEMS=3
HITL_INTERRUPT_ENABLED=true
ASYNC_CANCEL_ENABLED=true
REDIS_URL=redis://redis:6379/0
CANCEL_QUEUE_KEY=satmi:cancel:queue
CONVERSATION_INTENT_CLASSIFIER_ENABLED=true
CONVERSATION_INTENT_SHADOW_MODE=false
CONVERSATION_INTENT_USE_LLM_PRIMARY=true
CONVERSATION_INTENT_ALLOW_HEURISTIC_FALLBACK=false
CONVERSATION_INTENT_RAW_MODE=true
CONVERSATION_INTENT_RAW_DISABLE_REDACTION=false
CONVERSATION_INTENT_SOURCE_VERSION=conversation-intent-v2-raw

# Grafana credentials (used by docker-compose.production.yml)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_this_password
